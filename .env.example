# ============================================================
# Dimed-LIS - Configuracion de Entorno
# ============================================================
# Copiar a .env y ajustar valores antes de ejecutar

# --- Base de datos ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=dimed_lis
PG_USER=dimed
PG_PASSWORD=changeme_strong_password

# --- Seguridad ---
JWT_SECRET=changeme_generate_with_uuidgen
# openssl rand -hex 32

# --- Puertos de servicio ---
LIS_PORT=9008
BILLING_PORT=9009
WEB_PORT=9100
PG_EXT_PORT=5434

# --- SRI Ecuador (Facturacion Electronica) ---
SRI_AMBIENTE=1
# 1 = Pruebas, 2 = Produccion
SRI_RUC=
SRI_RAZON_SOCIAL=
SRI_NOMBRE_COMERCIAL=
SRI_DIRECCION_MATRIZ=
SRI_CERT_PATH=/certs/firma.p12
SRI_CERT_PASSWORD=

# --- Notificaciones (opcional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
LIS_SERVICE_TOKEN=
# Generate: docker exec dimed-lis-core python3 -c "import jwt,os; print(jwt.encode({'sub':'notify','role':'admin','exp':9999999999},os.environ['JWT_SECRET'],'HS256'))"

# --- Licencia Dimed ---
LICENSE_KEY=
LICENSE_SERVER=https://tu-servidor:8099/api/license

# --- Configuracion general ---
FLASK_DEBUG=false
TZ=America/Guayaquil
